{
  "name": "@recursica/storybook-template",
  "description": "Common Storybook configuration and templates for Recursica packages and apps",
  "private": false,
  "homepage": "https://github.com/borderux/recursica/tree/main/packages/storybook-template",
  "author": "hi@borderux.com",
  "bugs": {
    "url": "https://github.com/borderux/recursica/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borderux/recursica.git"
  },
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./main": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.cjs"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.js",
      "require": "./dist/manager.cjs"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "storybook",
    "react",
    "typescript",
    "recursica",
    "design system",
    "configuration"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "dev": "tsc -b --watch"
  },
  "dependencies": {
    "@recursica/adapter-common": "*",
    "@recursica/recursica-postcss-vars": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@repo/typescript-config": "*",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "storybook": "^10.3.3"
  }
}
