{
  "name": "@recursica/recursica-postcss-vars",
  "version": "1.0.0",
  "description": "PostCSS plugin to validate missing Recursica CSS variables against tokens JSON.",
  "private": false,
  "homepage": "https://github.com/borderux/recursica/tree/main/packages/recursica-postcss-vars",
  "author": "hi@borderux.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borderux/recursica.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "postcss": "^8.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@types/node": "^20.0.0",
    "eslint": "9.28.0",
    "postcss": "^8.4.0",
    "typescript": "5.8.2"
  },
  "license": "MIT"
}
