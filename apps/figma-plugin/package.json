{
  "name": "@recursica/figma-plugin",
  "private": true,
  "version": "0.17.0",
  "description": "The Figma plugin for Recursica",
  "license": "MIT",
  "author": "hi@borderux.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borderux/recursica.git"
  },
  "keywords": [
    "figma",
    "plugin",
    "recursica",
    "design"
  ],
  "bugs": {
    "url": "https://github.com/borderux/recursica/issues"
  },
  "homepage": "https://github.com/borderux/recursica",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist dist-dev dist-test",
    "dev": "npm run clean && concurrently \"npm run dev:tsc\" \"npm run dev:ui\" \"npm run dev:lib\"",
    "dev:tsc": "tsc -b --watch --preserveWatchOutput",
    "dev:ui": "vite build --watch",
    "dev:lib": "vite build --config vite.config.lib.ts --watch",
    "build": "npm run clean && concurrently --kill-others-on-fail \"npm run build:ui\" \"npm run build:lib\"",
    "build:ui": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --config vite.config.lib.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "publish": "node scripts/publish.mjs",
    "export:csv": "npx -y tsx scripts/json-to-csv.ts --tokens export/recursica_tokens.json --brand export/recursica_brand.json --uiKit export/recursica_ui-kit.json --out export/recursica_variables.csv"
  },
  "dependencies": {
    "@mantine/core": "^8.3.12",
    "@mantine/hooks": "^8.3.12",
    "crypto-js": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router": "7.6.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "9.11.1",
    "@figma/plugin-typings": "1.113.0",
    "@types/archiver": "6.0.3",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "19.1.7",
    "@types/react-dom": "19.1.6",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react-swc": "3.10.2",
    "archiver": "7.0.1",
    "concurrently": "9.0.1",
    "eslint": "9.11.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "rimraf": "^6.1.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.39.1",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "2.2.0"
  }
}
